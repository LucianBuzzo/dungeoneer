            max: options.max,
            fixed: 2
        }).toString(), cents = dollar.split('.')[1];
        if (cents === undefined) dollar += '.00';
        else if (cents.length < 2) dollar = dollar + '0';
        if (dollar < 0) return '-$' + dollar.replace('-', '');
        else return '$' + dollar;
