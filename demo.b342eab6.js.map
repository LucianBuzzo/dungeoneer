            if (bits.length !== 2 || !parseInt(bits[0], 10) || !parseInt(bits[1], 10)) throw new Error("Chance: Invalid format provided. Please provide #d# where the first # is the number of dice to roll, the second # is the max of each die");
            for(var i = bits[0]; i > 0; i--)rolls[i - 1] = this.natural({
                min: 1,
